{
  "rewrites": [
    {
      "source": "/admin-portal",
      "destination": "https://edukia-server.vercel.app/admin-portal"
    },
    {
      "source": "/admin-portal/:path*",
      "destination": "https://edukia-server.vercel.app/admin-portal/:path*"
    }
  ],
  "headers": [
    {
      "source": "/admin-portal/:path*",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
